{
  "name": "meter-reader-backend",
  "version": "1.0.0",
  "description": "Water meter reading portal backend API",
  "private": true,
  "scripts": {
    "build": "esbuild src/handlers/*.ts --bundle --platform=node --target=node20 --outdir=dist --external:pg-native",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/aws-lambda": "^8.10.147",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.11.10",
    "esbuild": "^0.24.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.7.0"
  }
}
